APP_NAME="Warehouse Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:5000

# Database Configuration (Warehouse DB - Terpisah!)
DB_CONNECTION=pgsql
DB_HOST=postgres-warehouse
DB_PORT=5432
DB_DATABASE=warehouse_db
DB_USERNAME=warehouse_user
DB_PASSWORD=warehouse123

# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Hasura Configuration
HASURA_URL=http://hasura-warehouse:8080
HASURA_ADMIN_SECRET=adminsecret123

# Session & Cache
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug
