		{
			"name": "Service 2 - Order & Tracking (GraphQL)",
			"item": [
				{
					"name": "Create Order",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.data && jsonData.data.createOrder) {",
									"        pm.environment.set(\"tracking_number\", jsonData.data.createOrder.tracking_number);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "mutation CreateOrder($customerId: String!, $itemDesc: String!) {\n  createOrder(\n    customer_id: $customerId\n    item_description: $itemDesc\n  ) {\n    id\n    tracking_number\n    customer_id\n    item_description\n    status\n    created_at\n    histories {\n      id\n      location\n      description\n      updated_at\n    }\n  }\n}",
								"variables": "{\n  \"customerId\": \"budi@example.com\",\n  \"itemDesc\": \"Laptop Gaming ASUS ROG\"\n}"
							}
						},
						"url": {
							"raw": "http://localhost:4000/graphql",
							"protocol": "http",
							"host": ["localhost"],
							"port": "4000",
							"path": ["graphql"]
						},
						"description": "Create new order using GraphQL mutation"
					},
					"response": []
				},
				{
					"name": "Track Order",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "query TrackOrder($trackingNumber: String!) {\n  trackOrder(tracking_number: $trackingNumber) {\n    id\n    tracking_number\n    customer_id\n    item_description\n    status\n    created_at\n    histories {\n      id\n      location\n      description\n      updated_at\n    }\n  }\n}",
								"variables": "{\n  \"trackingNumber\": \"{{tracking_number}}\"\n}"
							}
						},
						"url": {
							"raw": "http://localhost:4000/graphql",
							"protocol": "http",
							"host": ["localhost"],
							"port": "4000",
							"path": ["graphql"]
						}
					},
					"response": []
				},
				{
					"name": "Update Tracking",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "mutation UpdateTracking(\n  $trackingNumber: String!\n  $location: String!\n  $description: String!\n  $status: String!\n) {\n  updateTracking(\n    tracking_number: $trackingNumber\n    location: $location\n    description: $description\n    status: $status\n  ) {\n    id\n    tracking_number\n    status\n    histories {\n      location\n      description\n      updated_at\n    }\n  }\n}",
								"variables": "{\n  \"trackingNumber\": \"{{tracking_number}}\",\n  \"location\": \"Jakarta Pusat\",\n  \"description\": \"Paket sedang dalam perjalanan\",\n  \"status\": \"IN_TRANSIT\"\n}"
							}
						},
						"url": {
							"raw": "http://localhost:4000/graphql",
							"protocol": "http",
							"host": ["localhost"],
							"port": "4000",
							"path": ["graphql"]
						}
					},
					"response": []
				}
			]
		},
